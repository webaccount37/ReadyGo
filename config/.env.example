# ---------------------------------------------------------------------------
# Local development (copy to backend/.env and frontend/.env.local)
# ---------------------------------------------------------------------------
# Backend Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/readygo
REDIS_URL=redis://localhost:6379/0

# CORS (include every browser origin that calls the API)
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Azure Storage — local/dev often uses account key; in Azure Container Apps prefer
# managed identity (leave AZURE_STORAGE_ACCOUNT_KEY empty) and set AZURE_MANAGED_IDENTITY_CLIENT_ID.
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_EXPENSE_RECEIPTS_CONTAINER=expense-receipts
AZURE_STORAGE_ACCOUNT_DOCUMENTS_CONTAINER=account-documents

# Entra ID (Azure AD) SSO — public identifiers; client secret is sensitive
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_KEY_VAULT_URL=
# User-assigned managed identity client id (Azure only). Not the same as AZURE_CLIENT_ID.
AZURE_MANAGED_IDENTITY_CLIENT_ID=

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=readygo-backend
OTEL_ENVIRONMENT=development

# Security (never commit real values)
SECRET_KEY=change-me-in-production-use-a-secure-random-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# Frontend (local)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Azure Container Apps / Key Vault (do not copy real secrets into git)
# ---------------------------------------------------------------------------
# DATABASE_URL, SECRET_KEY, AZURE_CLIENT_SECRET → stored in Key Vault and
# injected as Container Apps secret references by infra/main.bicep.
# AZURE_STORAGE_ACCOUNT_KEY → omit in Azure; use managed identity + RBAC.
# NEXT_PUBLIC_* and Entra tenant/client id for the SPA are public at build/runtime;
# configure them as ACA environment variables or Docker build args per environment.
